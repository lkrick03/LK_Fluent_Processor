graph TD
    %% Define Colorful Node Styles
    classDef startend fill:#f5f5f5,stroke:#333333,color:#333333,stroke-width:2px;
    classDef input fill:#e3f2fd,stroke:#1565c0,color:#0d47a1,stroke-width:2px;
    classDef process fill:#fff3e0,stroke:#ef6c00,color:#e65100,stroke-width:2px;
    classDef decision fill:#fff9c4,stroke:#fbc02d,color:#ef6c00,stroke-width:2px;
    classDef conv fill:#f3e5f5,stroke:#8e24aa,color:#4a148c,stroke-width:2px;
    classDef output fill:#e8f5e9,stroke:#2e7d32,color:#1b5e20,stroke-width:2px;
    classDef error fill:#ffebee,stroke:#c62828,stroke-width:2px,color:#b71c1c;

    %% Subgraph Styling (Invisible boxes, black titles)
    style Data fill:none,stroke:none,color:#000000;
    style Conv fill:none,stroke:none,color:#000000;

    %% Nodes
    start([Start]) --> input_node[Define Data Sources]:::input
    input_node --> load[Part 1: Load & Validate]:::process
    
    subgraph Data [Data Processing]
        direction LR
        load --> scan[Scan Configs]:::process
        scan --> val{Valid?}:::decision
        val -- No --> log[Log Error]:::error
        val -- Yes --> proc[Parse & Correct Forces]:::process
        log --> report[Update Report]:::output
        proc --> store[Store Data]:::process
        class scan,proc,store process
    end
    
    store --> check_conv{Run Matrix?}:::decision
    
    check_conv -- No --> excel
    check_conv -- Yes --> opt[Part 2: Convergence Analysis]:::conv
    
    subgraph Conv [Convergence Optimization]
        direction LR
        opt --> trim[Iterative Data Trimming]:::conv
        trim --> stats[Calculate Confidence]:::conv
        stats --> rec[Select Optimal Trim]:::output
        rec --> cplot[Generate Conv. Plots]:::output
    end
    
    cplot --> excel[Part 3: Excel Summary]:::process
    excel --> sheet1[Create Data Sheets]:::process
    sheet1 --> sheet2[Create Comparison Sheets]:::process
    
    sheet2 --> gen_graphs[Part 4: Coefficient Graphs]:::process
    gen_graphs --> plots[Generate C_L, C_D, Polar Plots]:::output
    plots --> finish([End]):::startend
    
    %% Apply Start/End styles
    class start,finish startend;
