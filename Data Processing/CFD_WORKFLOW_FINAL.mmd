%%{init: {'theme': 'default', 'themeVariables': { 'background': '#ffffff', 'edgeLabelBackground':'#ffffff' }}}%%
graph TD
    %% Node Styles
    classDef startend fill:#ffffff,stroke:#333333,color:#333333,stroke-width:2px;
    classDef input fill:#e3f2fd,stroke:#1565c0,color:#0d47a1,stroke-width:2px;
    classDef process fill:#fff3e0,stroke:#ef6c00,color:#e65100,stroke-width:2px;
    classDef decision fill:#fff9c4,stroke:#fbc02d,color:#ef6c00,stroke-width:2px;
    classDef conv fill:#f3e5f5,stroke:#8e24aa,color:#4a148c,stroke-width:2px;
    classDef output fill:#e8f5e9,stroke:#2e7d32,color:#1b5e20,stroke-width:2px;
    classDef error fill:#ffebee,stroke:#c62828,stroke-width:2px,color:#b71c1c;

    %% Subgraph Styling
    style Startup fill:#ffffff,stroke-width:0px,color:#000000;
    style DataProcess fill:#ffffff,stroke-width:0px,color:#000000;
    style DecisionLogic fill:#ffffff,stroke-width:0px,color:#000000;
    style ConvOpt fill:#ffffff,stroke-width:0px,color:#000000;
    style FinalOutput fill:#ffffff,stroke-width:0px,color:#000000;

    subgraph Startup [Initialization]
        direction LR
        start([Start]) --> in[Define Data Sources]:::input
    end

    in --> load[Part 1: Load & Validate]:::process
    
    subgraph DataProcess [Data Processing]
        direction LR
        load --> scan[Scan Folders]:::process
        scan --> val{Valid?}:::decision
        val -- No --> log[Log Error]:::error
        val -- Yes --> proc[Extract forces]:::process
        log --> rep[Update Report]:::output
        proc --> store[Store Data]:::process
    end
    
    store --> matrix_node

    subgraph DecisionLogic [Control Logic]
        matrix_node{Run matrix?}:::decision
    end
    
    matrix_node -- No --> excel
    matrix_node -- Yes --> opt[Part 2: Convergence]:::conv
    
    subgraph ConvOpt [Convergence Optimization]
        direction LR
        opt --> trim[Iterative Trimming]:::conv
        trim --> conf[Calc Confidence]:::conv
        conf --> rec[Select Trim]:::output
        rec --> cplot[Generate Plots]:::output
    end
    
    cplot --> excel
    
    subgraph FinalOutput [Reporting & Visualization]
        direction LR
        excel[Part 3: Excel Summary]:::process --> s1[Create Data Sheets]:::process
        s1 --> s2[Create Comparison]:::process
        s2 --> process_graphs[Part 4: Graphs]:::process
        process_graphs --> plots[Generate Plots]:::output
        plots --> finish([End]):::startend
    end

    class start,finish startend;
