> ; ============================================================
; MAIN LOOP
; ============================================================

adjoint/                parallel/               server/
define/                 parametric-study/       solve/
display/                plot/                   surface/
exit                    preferences/            turbo-workflow/
file/                   print-license-usage     views/
mesh/                   report/

> (do ((aoa aoa_start (+ aoa aoa_step)))
    ((> aoa aoa_end))
  
  (newline)
  (display "===== AoA = ")
  (display aoa)
  (display " =====")
  (newline)
  
  (define aoa_rad (deg-to-rad aoa))
  (define V_x (* V_mag (cos aoa_rad)))
  (define V_y (* V_mag (sin aoa_rad)))
  
  ; Apply velocity inlet BCs
  (for-each
    (lambda (zone-name)
      (ti-menu-load-string
        (string-append "/define/boundary-conditions/velocity-inlet " zone-name 
          " no yes yes no 0 yes no " (number->string V_x)
          " no " (number->string V_y)
          " no 0 no no yes 0.05 10")))
    (get-inlet-zones aoa))
  
  ; Apply pressure outlet BCs
  (for-each
    (lambda (zone-name)
      (ti-menu-load-string
        (string-append "/define/boundary-conditions/pressure-outlet " zone-name
          " yes no 0 no yes no no yes 0.05 10 yes no no")))
    (get-outlet-zones aoa))
  
  ; Apply symmetry BCs
  (for-each
    (lambda (zone-name)
      (ti-menu-load-string
        (string-append "/define/boundary-conditions/symmetry " zone-name)))
    (get-symmetry-zones aoa))
  
  ; Update report file paths
  (ti-menu-load-string
    (string-append "/solve/report-files/edit " drag-report-file-name
      " file-name " base-output-dir "/drag_force_AoA_" (number->string aoa) ".txt q"))
  (ti-menu-load-string
    (string-append "/solve/report-files/edit " lift-report-file-name
      " file-name " base-output-dir "/lift_force_AoA_" (number->string aoa) ".txt q"))
  
  ; Run solver
  (ti-menu-load-string "/solve/iterate 1200")
  
  ; Save case and data
  (ti-menu-load-string
    (string-append "/file/write-case-data " base-output-dir "/3.1.1.NG." (number->string aoa) ".cas.h5 yes"))
  
  (display "AoA = ")
  (display aoa)
  (display " complete!")
  (newline))

